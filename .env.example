# PÅKREVD - hent på https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# VALGFRITT - https://finnhub.io/register (gratis, kun US-tickere).
# Tom = Yahoo Finance dekker alt (Oslo Børs, indekser, futures, valuta).
FINNHUB_API_KEY=

# Modell: haiku = billig og rask (anbefalt til daglig bruk).
# Mer analytisk dybde (ca. 3-5x dyrere): ANTHROPIC_MODEL=claude-sonnet-4-6
# Egen modell kun for chat: ANTHROPIC_CHAT_MODEL=...
ANTHROPIC_MODEL=claude-haiku-4-5

# Kostnadstak per dag (kredittvern - felles for alle som bruker siden)
MAX_BRIEFS_PER_DAY=6
MAX_CHATS_PER_DAY=60
# Finjustering: BRIEF_MAX_SEARCHES=8  BRIEF_MAX_TOKENS=3500  CHAT_MAX_SEARCHES=3  CHAT_MAX_TOKENS=1200

# Deling: sett en tilgangskode FØR du deler lenken med venner (tom = åpen lokalt)
SITE_PASSWORD=

PORT=3000
