# PÅKREVD - hent på https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# VALGFRITT - https://finnhub.io/register (gratis, kun US-tickere).
# Tom = Yahoo Finance dekker alt (Oslo Børs, indekser, futures, valuta).
FINNHUB_API_KEY=

# Modell: haiku = billig og rask (anbefalt til daglig bruk).
# Mer analytisk dybde (ca. 3-5x dyrere): ANTHROPIC_MODEL=claude-sonnet-4-6
# Egen modell kun for chat: ANTHROPIC_CHAT_MODEL=...
ANTHROPIC_MODEL=claude-haiku-4-5

# Kostnadstak per dag (kredittvern - felles for alle som bruker siden).
# Briefen er cache-først: visninger koster aldri API-kall; taket gjelder kun
# faktiske genereringer (1 vanlig + 1 re-kjøring som standard).
MAX_BRIEFS_PER_DAY=2
MAX_CHATS_PER_DAY=60

# KV/Redis (KUN nødvendig på Vercel/serverless - lokalt brukes filer automatisk).
# Legg til "Upstash for Redis" via Vercel Marketplace, så settes disse automatisk:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Finjustering: BRIEF_MAX_SEARCHES=8  BRIEF_MAX_TOKENS=3500  CHAT_MAX_SEARCHES=3  CHAT_MAX_TOKENS=1200

# Fase 1 datalag (alle valgfrie - widgets skjules/viser feil ærlig uten dem)
# FRED (makrotall USA): gratis nøkkel på https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# SEC EDGAR krever identifiserende kontakt i User-Agent (fair access policy):
EDGAR_CONTACT=din@epost.no

# Deling: sett en tilgangskode FØR du deler lenken med venner (tom = åpen lokalt)
SITE_PASSWORD=

PORT=3000
